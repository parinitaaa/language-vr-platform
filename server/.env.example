# =============================================================
# Language Learning VR Platform — Server Environment Variables
# =============================================================
# Copy this file to .env and fill in your values before running
# the server. Never commit your .env file to version control.
#
#   cp .env.example .env
# =============================================================


# -------------------------------------------------------------
# SERVER
# -------------------------------------------------------------

# Port that the Express server listens on.
# Default is 5000. Change only if that port is already in use.
PORT=5000


# -------------------------------------------------------------
# MONGODB
# -------------------------------------------------------------

# Full MongoDB connection string.
#
# Option A — MongoDB Atlas (cloud, recommended):
#   1. Log in to https://www.mongodb.com/atlas
#   2. Open your cluster → Connect → Drivers → Node.js
#   3. Copy the connection string and replace <username> and <password>
#      with your Atlas database user credentials.
#
# Option B — Local MongoDB:
#   MONGO_URI=mongodb://localhost:27017/language-platform
#
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/language-platform?retryWrites=true&w=majority


# -------------------------------------------------------------
# JSON WEB TOKEN (JWT)
# -------------------------------------------------------------

# Secret key used to sign and verify authentication tokens.
# Use a long, random, unpredictable string — at least 32 characters.
# Generate one with: openssl rand -hex 32  (in Git Bash / terminal)
# IMPORTANT: If you change this after users have logged in,
# all existing sessions will be invalidated.
JWT_SECRET=your_jwt_secret_key_here

# How long a JWT token stays valid before the user must log in again.
# Examples: 7d (7 days), 24h (24 hours), 60m (60 minutes)
JWT_EXPIRE=7d
