# Server Environment Variables
# The port the backend server will run on
PORT=5000

# MongoDB Connection String
# Example: mongodb://127.0.0.1:27017/language-platform (local)
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/language-platform (MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/language-platform

# JWT Secret Key for authenticating users
# Change this to a secure random string for production
JWT_SECRET=super_secret_jwt_key_12345
